# Admin (required in production; optional in dev, defaults to admin1234)
ADMIN_PASSWORD=your-secure-password

# Contact form email notifications (optional). Get API key at https://resend.com
RESEND_API_KEY=re_xxxx
# Sender email must be verified in Resend (or use onboarding@resend.dev for testing)
RESEND_FROM=The Painters <onboarding@resend.dev>

# Site URL for sitemap/robots (optional)
NEXT_PUBLIC_SITE_URL=https://thepainterslb.com
